generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProductBadge {
  NEW
  HOT
  SALE
}

enum ProductSize {
  small
  medium
  large
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  cod
  qr
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Product {
  id          Int           @id @default(autoincrement())
  sku         String?       @unique
  name        String
  slug        String        @unique
  category    String
  price       Float
  salePrice   Float?
  costPrice   Float?
  image       String
  images      String[]      @default([])
  description String
  size        ProductSize   @default(small)
  badge       ProductBadge?
  rating      Float         @default(0)
  inStock     Boolean       @default(true)
  inventory   Int?
  richText    String?
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orderItems OrderItem[]
  reviews    Review[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  image       String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                String        @id
  status            OrderStatus   @default(pending)
  reviewEnabled     Boolean       @default(true)
  total             Float
  customerName      String
  customerPhone     String
  customerAddress   String
  customerNote      String?
  locationLat       Float?
  locationLng       Float?
  paymentMethod     PaymentMethod @default(cod)
  paymentQrLabel    String?
  paymentScreenshot String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  items   OrderItem[]
  reviews Review[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   String
  productId Int
  name      String
  quantity  Int
  price     Float
  reviewed  Boolean @default(false)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Review {
  id            String   @id
  productId     Int
  productName   String
  orderId       String
  customerName  String
  customerPhone String
  rating        Int
  text          String
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])
}

model Banner {
  id         Int    @id @default(autoincrement())
  title      String
  subtitle   String @default("")
  buttonText String @default("")
  buttonLink String @default("")
  image      String
  order      Int    @default(0)
}

model Faq {
  id       Int     @id @default(autoincrement())
  question String
  answer   String
  order    Int     @default(0)
  active   Boolean @default(true)
}

model Message {
  id        String   @id
  name      String
  email     String
  phone     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id           Int      @id @default(autoincrement())
  filename     String   @unique
  originalName String
  url          String
  size         Int
  type         String
  alt          String   @default("")
  uploadedAt   DateTime @default(now())
}

// ─── Page Builder ────────────────────────────────────────────────────────────

model SavedTestimonial {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  text      String
  rating    Int      @default(5)
  image     String?
  createdAt DateTime @default(now())
}

model Page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  blocks    Json     @default("[]")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Auth (NextAuth / Auth.js) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────

model Settings {
  id                     Int     @id @default(1)
  storeName              String  @default("GMN Flower Store")
  phone                  String  @default("")
  email                  String  @default("")
  address                String  @default("")
  hours                  String  @default("")
  whatsappNumber         String  @default("")
  freeDeliveryThreshold  Float   @default(2000)
  currency               String  @default("NPR")
  socialFacebook         String  @default("")
  socialInstagram        String  @default("")
  socialYoutube          String  @default("")
  socialTiktok           String  @default("")
  homepageTabNewArrivals Boolean @default(true)
  homepageTabFlashSale   Boolean @default(true)
  homepageTabMostPopular Boolean @default(true)
  paymentQRCodes         Json    @default("[]")
  logo                   String  @default("")
  favicon                String  @default("")
}
